{
  "name": "zero-breach",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "A verifiable multiplayer AI red-team arena powered by 0G.",
  "homepage": "https://zero-breach.vercel.app",
  "repository": {
    "type": "git",
    "url": "https://github.com/giwaov/zero-breach.git"
  },
  "scripts": {
    "dev": "concurrently -n web,api -c magenta,cyan \"vite\" \"tsx watch server/index.ts\"",
    "dev:web": "vite",
    "dev:api": "tsx watch server/index.ts",
    "build": "tsc --noEmit && vite build",
    "start": "tsx server/index.ts",
    "test": "vitest run",
    "contract:build": "forge build",
    "contract:test": "forge test -vv"
  },
  "dependencies": {
    "@0gfoundation/0g-storage-ts-sdk": "1.2.10",
    "@rainbow-me/rainbowkit": "^2.2.11",
    "@tanstack/react-query": "^5.101.0",
    "dotenv": "16.5.0",
    "ethers": "6.13.1",
    "express": "5.1.0",
    "lucide-react": "0.468.0",
    "openai": "5.8.2",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "viem": "^2.52.2",
    "wagmi": "^2.19.5",
    "zod": "3.25.67"
  },
  "devDependencies": {
    "@types/express": "5.0.3",
    "@types/node": "22.15.32",
    "@types/react": "18.3.23",
    "@types/react-dom": "18.3.7",
    "@vitejs/plugin-react": "4.3.3",
    "concurrently": "9.1.2",
    "tsx": "4.20.3",
    "typescript": "5.8.3",
    "vite": "5.4.10",
    "vitest": "3.2.4"
  },
  "overrides": {
    "axios": "1.18.0",
    "ws": "8.21.0"
  }
}
